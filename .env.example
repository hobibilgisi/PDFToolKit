# PDFToolKit — Yapılandırma Dosyası
# Bu dosyayı .env olarak kopyalayın ve gerekli değerleri doldurun.
# (Çoğu durumda değiştirmenize gerek yoktur)

# ─── Tesseract OCR Yolu ────────────────────────────────────────────────────
# Boş bırakırsanız program, kendi yanındaki tesseract/ klasörünü otomatik bulur.
# Tesseract farklı bir yere kuruluysa tam yolu girin:
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_PATH=

# ─── Klasör Adları ─────────────────────────────────────────────────────────
# Gizli .pdf_data/ klasörü içindeki alt dizin adları.
# Değiştirmeniz önerilmez.
PDF_INPUT_DIR=input
PDF_OUTPUT_DIR=output

# ─── Loglama ───────────────────────────────────────────────────────────────
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── Güncelleme ────────────────────────────────────────────────────────────
# "Bu sürümü atla" dediğinizde uygulama buraya yazar.
# Elle düzenlemek için sürüm numarasını girin:
SKIPPED_UPDATE_VERSION=
